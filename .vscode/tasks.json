{
  "version": "2.0.0",
  "tasks": [
    {
        "label": "Start Frontend",
        "type": "shell",
        "command": "npm run dev",
        "options": {
            "cwd": "${workspaceFolder}/client"
        },
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "presentation": {
            "reveal": "always",
            "panel": "new"
        },
        "problemMatcher": []
    },
    {
        "label": "Start Backend",
        "type": "shell",
        "command": "npx tsx watch src/index.ts",
        "options": {
            "cwd": "${workspaceFolder}/server"
        },
        "presentation": {
            "reveal": "always",
            "panel": "new"
        },
        "problemMatcher": []
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Frontend", "Start Backend"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
]
}